# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sullivan

# Redis
REDIS_URL=redis://localhost:6379

# API Keys
GMGN_API_KEY=your_gmgn_api_key_here
GMGN_ED25519_PRIVATE_KEY=your_ed25519_private_key_hex
ANTHROPIC_API_KEY=your_anthropic_key_here
TELEGRAM_BOT_TOKEN=your_telegram_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Trading Parameters
MAX_POSITION_SIZE_USD=1000.0
MIN_SIGNAL_SCORE=65
MAX_CLAUDE_CALLS_PER_HOUR=15
SUPPORTED_CHAINS=["solana", "bsc", "base"]
DEFAULT_SLIPPAGE_TOLERANCE=0.05

# Rate Limiting
GMGN_RATE_LIMIT_PER_MINUTE=60
CLAUDE_CACHE_TTL_SECONDS=600

# Risk Management
DAILY_LOSS_LIMIT_PERCENT=12
WEEKLY_LOSS_LIMIT_PERCENT=25
MAX_OPEN_POSITIONS=4
STOP_LOSS_PERCENT=25
TAKE_PROFIT_PERCENT=100
TRAILING_STOP_PERCENT=20
